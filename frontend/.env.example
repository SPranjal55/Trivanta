# Copy to ".env.local" and adjust if your XAMPP path or port differs.
#
# Full URL to the folder that contains register.php (no trailing slash)
# Example when project is at C:\xampp\htdocs\trivanta\backend\api
# VITE_API_BASE_URL=http://localhost/trivanta/backend/api
#
# If Apache uses another port (e.g. 8080):
# VITE_API_BASE_URL=http://localhost:8080/trivanta/backend/api
#
# Vite dev proxy target (only used when you do NOT set VITE_API_BASE_URL)
# Must match where Apache serves backend/api
# VITE_PROXY_TARGET=http://127.0.0.1/trivanta/backend/api
